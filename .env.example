# Site
NEXT_PUBLIC_SITE_URL=https://www.haxrsignature.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Admin — usar secret independente da password
ADMIN_EMAIL=admin@haxrsignature.com
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email transaccional — Resend (formulário de contacto)
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=hello@haxrsignature.com
RESEND_FROM_EMAIL=HAXR Signature <hello@haxrsignature.com>
RESEND_BRAND_DOMAIN=true

# Marketing — Brevo (sync leads + funil)
BREVO_API_KEY=
BREVO_LIST_LEADS=
BREVO_LIST_NEWSLETTER=
BREVO_SENDER_EMAIL=hello@haxrsignature.com
BREVO_SENDER_NAME=HAXR Signature
BREVO_FUNNEL_ENABLED=true
BREVO_FUNNEL_PORTFOLIO_DAYS=3
BREVO_FUNNEL_EXPERIENCES_DAYS=7
BREVO_FUNNEL_MEETING_DAYS=14
BREVO_FUNNEL_LAST_CALL_DAYS=21

# Cron Vercel — follow-ups do funil (/api/cron/brevo-funnel)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Opcional — MCP Brevo no Cursor (não necessário na Vercel)
# BREVO_MCP_TOKEN=
